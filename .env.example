# Piezauto — Variables de entorno
# Copiá este archivo como .env y completá los valores reales.
# NUNCA commitees el .env con valores reales al repositorio.

# ── Supabase ────────────────────────────────────────────────────────────────
# URL del proyecto Supabase (Settings → API → Project URL)
SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave pública anon (Settings → API → anon public)
# Esta clave es segura para exponer en el frontend — usa las Row Level Security policies
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Google Analytics / GTM (opcional) ───────────────────────────────────────
# Measurement ID de GA4 (empieza con G-)
# Se agrega en el bloque comentado de cada HTML antes del lanzamiento
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ID de contenedor de Google Tag Manager (empieza con GTM-)
GTM_CONTAINER_ID=GTM-XXXXXXX

# ── Netlify (solo si usás Netlify) ──────────────────────────────────────────
# Estas variables NO se usan en el código frontend, son solo para CI/CD
NETLIFY_SITE_ID=tu-site-id
NETLIFY_AUTH_TOKEN=tu-token

# ── Notas de configuración ──────────────────────────────────────────────────
# Las credenciales del admin y talleres se guardan en la tabla "configuracion"
# de Supabase (clave/valor), NO en variables de entorno:
#   admin_email         → email del administrador
#   admin_password_hash → contraseña del admin (texto plano)
#   wa_flotante         → número de WhatsApp sin + (ej. 5491112345678)
#   wa_mensaje_bienvenida → texto del botón asesor WA
#   direccion           → dirección visible en topbar
#   horarios_por_dia    → JSON con horarios por día de la semana
